        {
          "expr": "rate(redis_rejected_connections_total[5m])",
          "legendFormat": "Rejected/s",
          "refId": "B"
        }
      ],
      "title": "Connection Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Keys & Hit Rate",

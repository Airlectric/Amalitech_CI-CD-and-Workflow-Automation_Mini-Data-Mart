{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Connections & Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{ datname }} - {{ state }}",
          "refId": "A"
        }
      ],
      "title": "Active Connections by Database & State",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "pg_settings_max_connections",
          "legendFormat": "Max connections",
          "refId": "A"
        },
        {
          "expr": "sum(pg_stat_activity_count)",
          "legendFormat": "Current connections",
          "refId": "B"
        }
      ],
      "title": "Connection Utilization",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Database Size & Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "expr": "pg_database_size_bytes",
          "legendFormat": "{{ datname }}",
          "refId": "A"
        }
      ],
      "title": "Database Size",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{datname!=\"\"}[5m])",
          "legendFormat": "{{ datname }} fetched",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname!=\"\"}[5m])",
          "legendFormat": "{{ datname }} inserted",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname!=\"\"}[5m])",
          "legendFormat": "{{ datname }} updated",
          "refId": "C"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname!=\"\"}[5m])",
          "legendFormat": "{{ datname }} deleted",
          "refId": "D"
        }
      ],
      "title": "Tuple Operations Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Transactions & Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname!=\"\"}[5m])",
          "legendFormat": "{{ datname }} commits",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname!=\"\"}[5m])",
          "legendFormat": "{{ datname }} rollbacks",
          "refId": "B"
        }
      ],
      "title": "Transaction Rate (Commits vs Rollbacks)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 6,
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname!=\"\"} / (pg_stat_database_blks_hit{datname!=\"\"} + pg_stat_database_blks_read{datname!=\"\"})",
          "legendFormat": "{{ datname }}",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": ["postgresql", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PostgreSQL Metrics",
  "uid": "postgres-metrics",
  "version": 1
}
